{
  "manifest_version": 3,
  "name": "Baton — browser agent",
  "version": "0.1.0",
  "description": "A runtime-free agent brain (baton-core, compiled to WASM) driving a Chrome side-panel agent that can read pages and navigate tabs. No backend.",
  "minimum_chrome_version": "116",
  "permissions": ["tabs", "activeTab", "scripting", "storage", "sidePanel"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Open Baton side panel"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  }
}
