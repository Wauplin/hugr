{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hugr.dev/schemas/answer.schema.json",
  "title": "Answer",
  "description": "The uniform result of one ask to a Hugr subagent (ARCHITECTURE §18.1). The wire form of hugr_agent::Answer. Errors are answers: status \"error\" still yields this shape (and exit code 0 on a CLI).",
  "type": "object",
  "required": ["status", "message", "trace_id", "metadata"],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["success", "error"],
      "description": "Outcome to branch on."
    },
    "message": {
      "type": "string",
      "description": "The answer text, or the error text when status is \"error\"."
    },
    "trace_id": {
      "type": "string",
      "description": "The NEW trace this run persisted — the anchor for follow-ups and forks."
    },
    "blobs": {
      "type": "array",
      "description": "Outbound files, content-addressed.",
      "items": { "$ref": "ask.schema.json#/$defs/blob_handle" },
      "default": []
    },
    "metadata": { "$ref": "#/$defs/answer_meta" },
    "extra": {
      "description": "Agent-specific structured extras; never load-bearing for the contract."
    }
  },
  "$defs": {
    "answer_meta": {
      "type": "object",
      "description": "Mandatory accounting, derivable from the persisted trace alone (children included).",
      "required": [
        "duration_ms",
        "cost_micro_usd",
        "tokens_in",
        "tokens_out",
        "model_calls",
        "tool_calls",
        "per_tier"
      ],
      "properties": {
        "duration_ms": { "type": "integer", "minimum": 0 },
        "cost_micro_usd": {
          "type": "integer",
          "minimum": 0,
          "description": "Total cost in micro-USD (1 USD = 1000000)."
        },
        "tokens_in": { "type": "integer", "minimum": 0 },
        "tokens_out": { "type": "integer", "minimum": 0 },
        "model_calls": { "type": "integer", "minimum": 0 },
        "tool_calls": { "type": "integer", "minimum": 0 },
        "per_tier": {
          "type": "array",
          "items": { "$ref": "#/$defs/tier_spend" }
        }
      }
    },
    "tier_spend": {
      "type": "object",
      "required": [
        "selector",
        "model_calls",
        "tokens_in",
        "tokens_out",
        "cost_micro_usd"
      ],
      "properties": {
        "selector": {
          "type": "string",
          "description": "The tier this line aggregates (small / medium / big)."
        },
        "model_calls": { "type": "integer", "minimum": 0 },
        "tokens_in": { "type": "integer", "minimum": 0 },
        "tokens_out": { "type": "integer", "minimum": 0 },
        "cost_micro_usd": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
